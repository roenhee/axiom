# Spec-Design-Prototype Hub — 환경변수
# 이 파일을 .env로 복사한 뒤 실제 값을 채운다.
# .env는 절대 커밋하지 않는다 (.gitignore 처리됨).

# ============================================================
# Phase 0부터 필요
# ============================================================

# PostgreSQL 연결 문자열
# macOS (brew 설치, 본인 계정으로 superuser): postgresql://myname@localhost:5432/spec_hub_dev
# Linux (별도 사용자/비밀번호 설정): postgresql://myname:devpass@localhost:5432/spec_hub_dev
DATABASE_URL="postgresql://CHANGE_ME@localhost:5432/spec_hub_dev"

# Hub 자신의 외부 노출 base URL (이메일/링크/Export 안의 URL 생성에 사용)
HUB_BASE_URL="http://localhost:3000"

# ------------------------------------------------------------
# Dev 모드 로그인 우회 (사내 SSO 붙이기 전까지)
# ------------------------------------------------------------
# 결정 D-010 (docs/decisions.md) 참고. src/lib/auth/current-user.ts가 이 값을 읽고,
# 모든 요청을 이 user 로 인증한 것으로 취급한다.
# 사내 SSO 붙이는 시점에 이 두 변수는 사라지고 current-user.ts만 갈아끼우면 된다.
DEV_USER_EMAIL="dev@local"
DEV_USER_NAME="Dev User"

# ============================================================
# Phase 3부터 필요 (그전엔 비워둬도 됨)
# ============================================================

# Prototype repo 절대 경로
# 이 경로 안의 Git 레포를 Hub의 AI Runner가 worktree로 조작한다.
# 절대 코드에 하드코딩하지 말 것 (CLAUDE.md "방어 1" 원칙)
PROTOTYPE_REPO_PATH="/Users/CHANGE_ME/work/prototype-repo"

# Prototype Preview의 base URL
# 로컬: http://localhost:3001
# DB에는 절대 URL을 저장하지 않고 런타임에 이 값 + slug로 조합 ("방어 2" 원칙)
PROTOTYPE_PREVIEW_BASE_URL="http://localhost:3001"

# ============================================================
# Phase 4부터 필요
# ============================================================

# Anthropic API 키
# https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY="CHANGE_ME"

# Claude Code 실행 모드
# "cli" — claude CLI를 sub-process로 호출 (권장)
# "sdk" — Anthropic SDK 직접 사용
AI_RUNNER_MODE="cli"

# Claude Code 바이너리 경로 (cli 모드일 때)
# 빈 값이면 PATH에서 찾음
CLAUDE_CLI_PATH=""

# AI 작업 타임아웃 (초)
AI_TASK_TIMEOUT_SECONDS="600"

# ============================================================
# Phase 5부터 필요
# ============================================================

# Export zip 저장 디렉토리 (Hub repo 기준 상대 경로 또는 절대 경로)
EXPORT_STORAGE_DIR="./uploads/exports"

# ============================================================
# Phase 1 — 첨부파일 업로드 (D-038)
# ============================================================

# 첨부파일 저장 디렉토리. 프로젝트별로 하위 폴더가 생성됨:
# ${UPLOAD_STORAGE_DIR}/<projectId>/<storedName>.<ext>
UPLOAD_STORAGE_DIR="./uploads/attachments"

# D-045. PPTX/DOCX/XLSX → PDF 변환에 사용할 LibreOffice 실행 파일 경로.
# macOS (brew install --cask libreoffice):
#   /Applications/LibreOffice.app/Contents/MacOS/soffice
# Linux (sudo apt install libreoffice):
#   /usr/bin/soffice
# 비워두면 office 첨부 변환 비활성 — 미리보기 대신 다운로드만 노출.
LIBREOFFICE_PATH="/Applications/LibreOffice.app/Contents/MacOS/soffice"

# ============================================================
# 기타
# ============================================================

# 로그 레벨: debug | info | warn | error
LOG_LEVEL="info"
